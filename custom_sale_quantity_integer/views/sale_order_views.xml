<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_quantity_integer" model="ir.ui.view">
        <field name="name">sale.order.form.quantity.integer</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_uom_qty']" position="attributes">
                <attribute name="widget">integer</attribute>
            </xpath>
        </field>
    </record>
</odoo>