<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the sale order form view -->
    <record id="view_order_form_inherit_integer" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.quantity.integer</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Find the quantity field in the order lines tree -->
            <xpath expr="//field[@name='order_line']/tree//field[@name='product_uom_qty']" position="attributes">
                <attribute name="widget">integer</attribute>
            </xpath>
        </field>
    </record>
</odoo>