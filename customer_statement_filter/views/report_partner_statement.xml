<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_custom_statement" model="ir.actions.report">
        <field name="name">Customer Statement</field>
        <field name="model">res.partner</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">customer_statement_filter.report_details</field>
        <field name="report_file">customer_statement_filter.report_details</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
    </record>

    <template id="report_details">
        <t t-call="web.html_container">
            <t t-foreach="partner_statements" t-as="statement">
                <t t-set="o" t-value="statement['partner']"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row">
                            <div class="col-6">
                                <h3><strong>Statement</strong></h3>
                                <p>
                                    <span t-field="o.name"/><br/>
                                    <span t-field="o.street"/><br/>
                                    <span t-field="o.city"/>
                                </p>
                            </div>
                            <div class="col-6 text-end">
                                <h4>Statement Balance</h4>
                                <h2 t-esc="statement['ending_balance']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </div>
                        </div>

                        <table class="table table-sm mt-4">
                            <thead>
                                <tr class="border-black">
                                    <th>Date</th>
                                    <th>Reference</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-end">Running Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td colspan="3"><strong>Opening Balance</strong></td>
                                    <td class="text-end">
                                        <strong t-esc="statement['opening_balance']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>

                                <t t-foreach="statement['lines']" t-as="row">
                                    <tr>
                                        <td><span t-field="row['line'].date"/></td>
                                        <td><span t-field="row['line'].move_id.name"/></td>
                                        <td class="text-end">
                                            <span t-esc="row['amount']"
                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="row['running_balance']"
                                                  t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td colspan="3"><strong>Ending Balance</strong></td>
                                    <td class="text-end">
                                        <strong t-esc="statement['ending_balance']" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>