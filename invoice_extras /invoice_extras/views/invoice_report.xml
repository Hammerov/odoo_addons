<odoo>

    <template id="report_invoice_document_inherit_extras"
              inherit_id="account.report_invoice_document">

        <xpath expr="//div[@class='row']" position="after">

            <div class="row mt-2">

                <div class="col-6">
                    <strong>Delivery Note No:</strong>
                    <span t-field="o.delivery_note_no"/>
                </div>

                <div class="col-6">
                    <strong>L.P.O Number:</strong>
                    <span t-field="o.lpo_number"/>
                </div>

            </div>

        </xpath>

    </template>

</odoo>
