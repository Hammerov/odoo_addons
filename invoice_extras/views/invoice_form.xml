<odoo>

    <record id="view_move_form_invoice_extras" model="ir.ui.view">
        <field name="name">account.move.form.invoice.extras</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet//group" position="inside">

                <group string="Extra Information">

                    <field name="delivery_note_no"/>
                    <field name="lpo_number"/>

                </group>

            </xpath>

        </field>
    </record>

</odoo>
