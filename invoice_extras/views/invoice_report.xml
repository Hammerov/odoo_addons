<odoo>

    <template id="report_invoice_document_inherit_extras"
              inherit_id="account.report_invoice_document">

        <xpath expr="//div[@id='informations']/div[@name='due_date']" position="after">

            <div class="col-3 mb-2" t-if="o.delivery_note_no" name="delivery_note">
                <strong>D/Note</strong>
                <div t-field="o.delivery_note_no"/>
            </div>

            <div class="col-3 mb-2" t-if="o.lpo_number" name="lpo_no">
                <strong>L.P.O</strong>
                <div t-field="o.lpo_number"/>
            </div>

        </xpath>

    </template>

</odoo>