<odoo>

    <template id="report_invoice_document_inherit_extras"
              inherit_id="account.report_invoice_document">

        <xpath expr="//div[@id='informations']/div[@name='due_date']" position="after">
            <div class="col-auto mw-100 mb-2" t-if="o.delivery_note_no" name="delivery_note">
                <strong>Delivery Note No:</strong>
                <p class="m-0" t-field="o.delivery_note_no"/>
            </div>
            <div class="col-auto mw-100 mb-2" t-if="o.lpo_number" name="lpo_no">
                <strong>L.P.O Number:</strong>
                <p class="m-0" t-field="o.lpo_number"/>
            </div>
        </xpath>

    </template>

</odoo>