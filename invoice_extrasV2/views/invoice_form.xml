<odoo>
    <record id="view_move_form_invoice_extras" model="ir.ui.view">
        <field name="name">account.move.form.invoice.extras</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//group[@name='sale_info_group']" position="inside">
                <field name="delivery_note_no"/>
                <field name="lpo_number"/>
            </xpath>

            <xpath expr="//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="before">
                <field name="packs"/>
            </xpath>

        </field>
    </record>
</odoo>