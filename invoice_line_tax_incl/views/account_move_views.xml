<odoo>

    <!-- Modify the ACTUAL invoice line tree view -->
    <record id="view_invoice_line_tree_inherit_tax_incl" model="ir.ui.view">
        <field name="name">account.move.line.invoice.tree.tax.incl</field>
        <field name="model">account.move.line</field>

        <!-- THIS is the correct view in Odoo 19 -->
        <field name="inherit_id" ref="account.view_invoice_line_tree"/>

        <field name="arch" type="xml">

            <xpath expr="//field[@name='price_subtotal']" position="after">
                <field name="price_total" string="Incl. Tax" widget="monetary"/>
            </xpath>

        </field>
    </record>

</odoo>