<odoo>

    <record id="view_move_form_inherit_tax_incl" model="ir.ui.view">
        <field name="name">account.move.form.tax.incl.safe</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Target ANY tree inside invoice_line_ids -->
            <xpath expr="//field[@name='invoice_line_ids']//tree//field[@name='name']" position="after">
                <field name="price_total" string="Incl. Tax" widget="monetary"/>
            </xpath>

        </field>
    </record>

</odoo>