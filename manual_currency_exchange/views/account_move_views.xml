<?xml version="1.0" encoding="utf-8"?>

<odoo>

    <record id="view_move_form_manual_currency" model="ir.ui.view">
        <field name="name">account.move.form.manual.currency</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='currency_id']" position="after">

                <field name="use_manual_currency_rate"/>

                <field name="manual_currency_rate"
                       attrs="{'invisible': [('use_manual_currency_rate','=',False)]}"/>

            </xpath>

        </field>
    </record>

</odoo>