<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- 1. MODIFIES THE SCREEN (Form View) -->
    <record id="view_delivery_slip_form_inherit_pack" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.pack</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Simplified XPath: Look for product_id inside the move_ids field -->
            <xpath expr="//field[@name='move_ids']//field[@name='product_id']" position="after">
                <field name="pack"/>
            </xpath>
        </field>
    </record>

    <!-- 2. MODIFIES THE PRINTED PDF (Delivery Slip) -->
    <template id="report_delivery_slip_pack_pdf" inherit_id="stock.report_delivery_document">
        <!-- Add Header -->
        <xpath expr="//table[@name='stock_move_table']/thead/tr" position="inside">
            <th name="th_pack"><strong>Packs</strong></th>
        </xpath>
        
        <!-- Add Data Cell -->
        <xpath expr="//table[@name='stock_move_table']/tbody/tr" position="inside">
            <td>
                <span t-field="move.pack"/>
            </td>
        </xpath>
    </template>
</odoo>


